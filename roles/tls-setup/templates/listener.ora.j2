LISTENER =
  (DESCRIPTION_LIST =
    (DESCRIPTION =
      (ADDRESS = (PROTOCOL = IPC)(KEY = EXTPROC1521))
      (ADDRESS = (PROTOCOL = TCP)(HOST = {{ ansible_hostname }})(PORT = {{ ora_listener_port | default('1521') }}))
      (ADDRESS = (PROTOCOL = TCPS)(HOST = {{ ansible_hostname }})(PORT = {{ ora_tls_listener_port | default('2484') }}))
    )
  )

SSL_CLIENT_AUTHENTICATION = FALSE
WALLET_LOCATION =
  (SOURCE =
    (METHOD = FILE)
    (METHOD_DATA =
      (DIRECTORY = {{ tls_wallet_dir }})
    )
  )
