#!/bin/bash

# Define the target response file
RSP_FILE="{{ swlib_unzip_path }}/grid_install.rsp"

# 1. Copy the appropriate template response file based on version
{% if oracle_ver is version('12.2.0.1.0', '<') %}
cp {{ swlib_unzip_path }}/grid/response/grid_install.rsp "${RSP_FILE}"
{% else %}
cp {{ grid_home }}/inventory/response/grid_install.rsp "${RSP_FILE}"
{% endif %}

# 2. Define Variable Mapping (Jinja2 determines the schema)
{% if oracle_ver is version('21.0.0.0.0', '<') %}
KEY_OPTION="oracle.install.option"
KEY_OSDBA="oracle.install.asm.OSDBA"
KEY_OSOPER="oracle.install.asm.OSOPER"
KEY_OSASM="oracle.install.asm.OSASM"
{% else %}
KEY_OPTION="installOption"
KEY_OSDBA="OSDBA"
KEY_OSOPER="OSOPER"
KEY_OSASM="OSASM"
{% endif %}

# 3. Apply Core Configuration
sed -i "s~^${KEY_OPTION}=.*~${KEY_OPTION}=CRS_SWONLY~" "${RSP_FILE}"
sed -i "s~^${KEY_OSDBA}=.*~${KEY_OSDBA}=asmdba~" "${RSP_FILE}"
sed -i "s~^${KEY_OSOPER}=.*~${KEY_OSOPER}=asmoper~" "${RSP_FILE}"
sed -i "s~^${KEY_OSASM}=.*~${KEY_OSASM}=asmadmin~" "${RSP_FILE}"

# 4. Standard Paths & Inventory
sed -i "s~^INVENTORY_LOCATION=.*~INVENTORY_LOCATION={{ oracle_root }}/oraInventory~" "${RSP_FILE}"
sed -i "s~^ORACLE_BASE=.*~ORACLE_BASE={{ oracle_base }}~" "${RSP_FILE}"

# 5. Optional Parameters (Only update if present in the source template)
if grep -q "^ORACLE_HOME=" "${RSP_FILE}"; then
  sed -i "s~^ORACLE_HOME=.*~ORACLE_HOME={{ grid_home }}~" "${RSP_FILE}"
fi

if grep -q "^ORACLE_HOSTNAME=" "${RSP_FILE}"; then
  sed -i "s~^ORACLE_HOSTNAME=.*~ORACLE_HOSTNAME=$(hostname -A | awk '{print $1}')~" "${RSP_FILE}"
fi
